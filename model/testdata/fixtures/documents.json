    },
    {
      "name": "description with link",
      "input": "<p>Data from <a href=\"https://www.geonames.org/\">GeoNames</a>.</p>",
      "doc": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Data from "
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "link",
                    "attrs": {
                      "href": "https://www.geonames.org/"
                    }
                  }
                ],
                "text": "GeoNames"
              },
              {
                "type": "text",
                "text": "."
              }
            ]
          }
        ]
      },
      "canonical": "<p>Data from <a href=\"https://www.geonames.org/\">GeoNames</a>.</p>"
    }
  ]
