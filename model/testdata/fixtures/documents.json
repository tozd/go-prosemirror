        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "hello world"
              }
            ]
          }
        ]
      },
      "canonical": "<p>hello world</p>"
    },
    {
      "name": "description block",
      "input": "<p>A document describes a property.</p>",
      "doc": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "A document describes a property."
              }
            ]
          }
        ]
      },
